{
  "name": "Alert",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo do alerta"
    },
    "type": {
      "type": "string",
      "enum": [
        "chuva_intensa",
        "alagamento",
        "deslizamento",
        "vendaval",
        "granizo",
        "outros"
      ],
      "description": "Tipo do alerta"
    },
    "severity": {
      "type": "string",
      "enum": [
        "baixo",
        "moderado",
        "alto",
        "critico"
      ],
      "description": "N\u00edvel de severidade"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada do alerta"
    },
    "affected_zones": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Zonas afetadas pelo alerta"
    },
    "source": {
      "type": "string",
      "description": "Fonte do alerta (ex: Defesa Civil, SIMEPAR)"
    },
    "start_date": {
      "type": "string",
      "format": "date-time",
      "description": "In\u00edcio do per\u00edodo de alerta"
    },
    "end_date": {
      "type": "string",
      "format": "date-time",
      "description": "Fim do per\u00edodo de alerta"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Se o alerta est\u00e1 ativo"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Recomenda\u00e7\u00f5es de seguran\u00e7a"
    }
  },
  "required": [
    "title",
    "type",
    "severity",
    "description"
  ]
}
